# ============================================
# Nexus User Management System - Environment Variables
# ============================================
# COPY THIS FILE TO .env AND CUSTOMIZE:
#   cp .env.example .env
# ALL CREDENTIALS BELOW ARE DEFAULTS. CHANGE THEM BEFORE PRODUCTION.
# ============================================

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_DB=nexusdb
POSTGRES_USER=nexus_user
POSTGRES_PASSWORD=change_me_postgres_2025

# ─────────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=nexus_user
MONGO_INITDB_ROOT_PASSWORD=change_me_mongo_2025

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_2025

# ─────────────────────────────────────────────
# RabbitMQ
# ─────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=nexus_user
RABBITMQ_DEFAULT_PASS=change_me_rabbit_2025
RABBITMQ_ERLANG_COOKIE=change_me_erlang_cookie_2025

# ─────────────────────────────────────────────
# JWT Configuration
# ─────────────────────────────────────────────
JWT_SECRET=change_me_jwt_secret_32_chars_min_2025
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────
# OpenAI (Optional - for AI Service)
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────
# Monitoring (Optional)
# ─────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change_me_grafana_2025
